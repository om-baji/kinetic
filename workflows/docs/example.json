{
  "workflow_name": "train-model",
  "tasks": [
    {
      "id": "download",
      "type": "docker"
    },
    {
      "id": "preprocess",
      "depends": ["download"]
    },
    {
      "id": "trainA",
      "depends": ["preprocess"]
    },
    {
      "id": "trainB",
      "depends": ["preprocess"]
    },
    {
      "id": "evaluate",
      "depends": ["trainA", "trainB"]
    },
    {
      "id": "upload",
      "depends": ["evaluate"]
    },
    {
      "id": "notify",
      "depends": ["upload"]
    }
  ]
}
